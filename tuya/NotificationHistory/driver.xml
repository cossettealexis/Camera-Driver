<devicedata>
    <copyright>Copyright © 2025 Slomins. All Rights Reserved.</copyright>
    <name>Notification History</name>
    <version>2</version>
    <creator>Slomins</creator>
    <manufacturer>Slomins</manufacturer>
    <model>NotificationHistory</model>
    <created>2026-02-26</created>
    <modified>2026-06-02</modified>
    <minimum_os_version>3.3.2</minimum_os_version>
    <control>lua_gen</control>
    <auto_update>true</auto_update>
    <driver>DriverWorks</driver>
     <proxies>
        <proxy proxybindingid="5001" name="Notification History"  image_source="c4z" large_image="icons/device_lg.png" small_image="icons/device_sm.png">uibutton</proxy>
    </proxies>
    <capabilities>
        <navigator_display_option proxybindingid="5001">
      <display_icons>
        <Icon width="70" height="70">controller://driver/NotificationHistory/icons/device/notif_70.png</Icon>
        <Icon width="90" height="90">controller://driver/NotificationHistory/icons/device/notif_90.png</Icon>
        <Icon width="300" height="300">controller://driver/NotificationHistory/icons/device/notif_300.png</Icon>
      </display_icons>
    </navigator_display_option>
        <web_view_url proxybindingid="5001">
            controller://driver/NotificationHistory/contents/index.html
        </web_view_url>
        <mobile_web_view_enabled>true</mobile_web_view_enabled>
    </capabilities>
    <config>
         <script file="driver.lua"/>
        <documentation file="README.md">Slomins UI Notification Documentation</documentation>
        <properties>
            <property>
                <name>Base API URL</name>
                <type>STRING</type>
                <default>https://api.arpha-tech.com</default>
                <readonly>false</readonly>
            </property>
            <property>
                <name>Account</name>
                <type>STRING</type>
                <default>cgabu@slomins.com</default>
                <readonly>false</readonly>
            </property>
            <property>
                <name>ClientID</name>
                <type>STRING</type>
                <default>064d0d44-29dd-48bc-9ff7-3f69bd24c91f</default>
                <readonly>false</readonly>
            </property>
            <property>
                <name>Public Key</name>
                <type>STRING</type>
                <default>
                </default>
                <readonly>false</readonly>
            </property>
           

            <property>
                <name>Auth Token</name>
                <type>STRING</type>
                <default></default>
                <readonly>false</readonly>
            </property>

            <property>
                <name>AppId</name>
                <type>STRING</type>
                <default></default>
                <readonly>false</readonly>
            </property>

            <property>
                <name>AppSecret</name>
                <type>STRING</type>
                <password>true</password>
                <default></default>
                <readonly>true</readonly>
            </property>

            <property>
                <name>Status</name>
                <type>STRING</type>
                <default>Initializing...</default>
                <readonly>true</readonly>
            </property>
        </properties>
        <commands>
    <command>
        <name>AuthTokenUpdate</name>
        <description>Send auth token to WebView</description>
    </command>
</commands>

        
    </config>

    <connections>

        <!-- UI BUTTON CONNECTION -->
        <connection>
      <id>5001</id>
      <facing>6</facing>
      <connectionname>UIBUTTON</connectionname>
      <type>2</type>
      <consumer>False</consumer>
      <audiosource>False</audiosource>
      <videosource>False</videosource>
      <linelevel>False</linelevel>
      <classes>
        <class>
          <classname>UIBUTTON</classname>
        </class>
      </classes>
    </connection>

        <!-- TCP CONNECTION (FOR AUTH TOKEN) -->
        <connection>
            <id>7001</id>
            <connectionname>TCP</connectionname>
            <type>4</type>
            <hidden>true</hidden>
            <consumer>true</consumer>
            <classes>
                <class>
                    <classname>TCP</classname>
                    <ports>
                        <port>
                            <number>8081</number>
                            <suppress_connection_events>True</suppress_connection_events>
                            <auto_connect>True</auto_connect>
                            <monitor_connection>True</monitor_connection>
                            <keep_connection>True</keep_connection>
                            <keep_alive>True</keep_alive>
                            <delimiter>0d0a</delimiter>
                        </port>
                    </ports>
                </class>
            </classes>
        </connection>

    </connections>

</devicedata>